{
  "name": "iztrack",
  "private": true,
  "version": "1.4.2",
  "description": "Sistema de gestion de ventas y caja.",
  "author": "izTrack",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "dist": "npm run build:prod && electron-builder",
    "release": "npm run build:prod && electron-builder --publish always",
    "postinstall": "node -e \"console.log('OK')\"",
    "licencia": "node generate-license.cjs"
  },
  "build": {
    "appId": "com.iztrack.app",
    "productName": "izTrack",
    "copyright": "Copyright 2026 izTrack",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "electron/*.ps1"
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "./public/log0.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "CARLOS-V-G",
      "repo": "iztrack-updates",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "izTrack-Setup-${version}.${ext}",
      "installerIcon": "./public/log0.ico",
      "uninstallerIcon": "./public/log0.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "izTrack",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "izTrack-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "bcryptjs": "^3.0.3",
    "electron-updater": "^6.6.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uiohook-napi": "^1.5.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "electron": "^41.9.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
